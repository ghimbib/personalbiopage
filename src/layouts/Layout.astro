---
import '../styles/global.css';
import {
  DEFAULT_DESCRIPTION,
  DEFAULT_IMAGE,
  DEFAULT_TITLE,
  absoluteUrl,
  webPageSchema,
} from '../utils/seo';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalPath?: string;
  type?: 'website' | 'article' | 'profile';
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
  noindex?: boolean;
}

const { 
  title = DEFAULT_TITLE,
  description = DEFAULT_DESCRIPTION,
  image = DEFAULT_IMAGE,
  canonicalPath = Astro.url.pathname,
  type = 'website',
  jsonLd,
  noindex = false
} = Astro.props;
const canonicalUrl = absoluteUrl(canonicalPath);
const imageUrl = absoluteUrl(image);
const jsonLdPayload = jsonLd ?? webPageSchema({ path: canonicalPath, title, description });
const jsonLdScript = JSON.stringify(jsonLdPayload).replace(/</g, '\\u003c');
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <script is:inline>
      (function(){
        var media = window.matchMedia('(prefers-color-scheme: dark)');

        function getPreferredTheme() {
          var saved = localStorage.getItem('theme');
          if (saved === 'light' || saved === 'dark') return saved;
          return media.matches ? 'dark' : 'light';
        }

        function applyTheme() {
          var theme = getPreferredTheme();
          document.documentElement.setAttribute('data-theme', theme);
          document.documentElement.style.colorScheme = theme;
          window.dispatchEvent(new CustomEvent('themechange', { detail: { theme: theme } }));
        }

        window.__getPreferredTheme = getPreferredTheme;
        window.__applyTheme = applyTheme;

        applyTheme();

        media.addEventListener('change', function() {
          var saved = localStorage.getItem('theme');
          if (saved !== 'light' && saved !== 'dark') {
            applyTheme();
          }
        });
      })();
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="author" content="Bibek Ghimire" />
    <meta name="theme-color" content="#F7F8F6" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0D1B2A" media="(prefers-color-scheme: dark)" />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <link rel="canonical" href={canonicalUrl} />
    <link rel="me" href="https://www.linkedin.com/in/bibek-ghimire/" />
    <link rel="me" href="https://github.com/ghimbib" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Bibek Ghimire" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:alt" content={title} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content={title} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="alternate" type="text/plain" href="/llms.txt" title="LLM-readable site summary" />
    <link rel="preload" as="image" href="/images/bibek-linkedin.png" fetchpriority="high" />
    <style is:inline>
      html{background:#F7F8F6;color:#111827;}
      html[data-theme="dark"]{background:#0D1B2A;color:#E8EDF2;}
      .skip-link{position:absolute;left:1rem;top:1rem;z-index:10000;transform:translateY(-150%);padding:.75rem 1rem;border-radius:.5rem;background:#0E9E92;color:#0D1B2A;font-weight:700;text-decoration:none;}
      .skip-link:focus{transform:translateY(0);outline:2px solid currentColor;outline-offset:2px;}
    </style>
    <title>{title}</title>

    <script is:inline>
      document.addEventListener('astro:after-swap', function(){
        if (window.__applyTheme) window.__applyTheme();
      });
    </script>

    <script type="application/ld+json" set:html={jsonLdScript}></script>

  </head>
  <body class="bg-bg text-text-primary antialiased">
    <a class="skip-link" href="#main-content">Skip to content</a>
    <!-- Custom cursor -->
    <div class="cursor" id="cursor"></div>
    <div class="cursor-dot" id="cursorDot"></div>
    
    <!-- Noise overlay -->
    <div class="noise-overlay"></div>

    <slot />

    <script>
      // ── Custom cursor ──
      const cursor = document.getElementById('cursor')!;
      const dot = document.getElementById('cursorDot')!;
      let mouseX = 0, mouseY = 0;
      let cursorX = 0, cursorY = 0;

      document.addEventListener('mousemove', (e) => {
        mouseX = e.clientX;
        mouseY = e.clientY;
        dot.style.left = mouseX + 'px';
        dot.style.top = mouseY + 'px';
      });

      function animateCursor() {
        cursorX += (mouseX - cursorX) * 0.15;
        cursorY += (mouseY - cursorY) * 0.15;
        cursor.style.left = cursorX + 'px';
        cursor.style.top = cursorY + 'px';
        requestAnimationFrame(animateCursor);
      }
      animateCursor();

      // Hover effect on interactive elements
      document.querySelectorAll('a, button, [data-hover]').forEach(el => {
        el.addEventListener('mouseenter', () => cursor.classList.add('hover'));
        el.addEventListener('mouseleave', () => cursor.classList.remove('hover'));
      });

      // ── Scroll-triggered animations ──
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              // Add stagger delay based on data attribute
              const delay = entry.target.getAttribute('data-delay') || '0';
              (entry.target as HTMLElement).style.transitionDelay = delay + 'ms';
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -60px 0px' }
      );

      document.querySelectorAll('[data-animate], [data-animate-left]').forEach((el) => {
        observer.observe(el);
      });

      // ── Stat counter animation ──
      const counterObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const el = entry.target as HTMLElement;
              const target = parseInt(el.getAttribute('data-count') || '0');
              const suffix = el.getAttribute('data-suffix') || '';
              let current = 0;
              const increment = target / 40;
              const timer = setInterval(() => {
                current += increment;
                if (current >= target) {
                  current = target;
                  clearInterval(timer);
                }
                el.textContent = Math.floor(current) + suffix;
              }, 30);
              counterObserver.unobserve(el);
            }
          });
        },
        { threshold: 0.5 }
      );

      document.querySelectorAll('[data-count]').forEach(el => {
        counterObserver.observe(el);
      });
    </script>
  </body>
</html>
