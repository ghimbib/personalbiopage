---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { caseStudies } from '../../data/caseStudies';

export function getStaticPaths() {
  return caseStudies.map((study) => ({
    params: { slug: study.slug },
    props: { study },
  }));
}

const { study } = Astro.props;
---

<Layout
  title={`${study.title} — Bibek Ghimire`}
  description={study.teaser}
>
  <Nav />
  <main class="pt-32 pb-20 px-6">
    <div class="max-w-3xl mx-auto">
      <a
        href="/work"
        class="inline-flex items-center gap-2 text-text-muted hover:text-accent transition-colors text-sm font-mono mb-8"
        data-hover
      >
        <span>←</span>
        <span>Back to case studies</span>
      </a>

      <header class="mb-12" data-animate>
        <div class="flex flex-wrap items-center gap-3 mb-4">
          <span class="text-xs px-2.5 py-1 rounded-full bg-accent-subtle text-accent border border-accent/20 font-mono">{study.company}</span>
          <span class="text-text-muted text-sm font-mono">{study.period}</span>
          <span class="text-border">·</span>
          <span class="text-text-muted text-sm font-mono">{study.role}</span>
        </div>
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold leading-tight mb-4">
          {study.title}
        </h1>
        <p class="text-text-secondary text-lg leading-relaxed">
          {study.summary}
        </p>
      </header>

      <section class="space-y-10" data-animate data-delay="100">
        <div class="bg-bg-card border border-border rounded-xl p-6">
          <p class="text-accent text-sm font-mono uppercase tracking-wider mb-3">The challenge</p>
          <p class="text-text-secondary leading-relaxed">{study.challenge}</p>
        </div>

        <div>
          <h2 class="text-2xl font-bold mb-4">What I owned</h2>
          <ul class="space-y-3 text-text-secondary leading-relaxed pl-5">
            {study.responsibilities.map((item) => (
              <li class="list-disc">{item}</li>
            ))}
          </ul>
        </div>

        <div>
          <h2 class="text-2xl font-bold mb-4">What changed</h2>
          <ul class="space-y-3 text-text-secondary leading-relaxed pl-5">
            {study.outcomes.map((item) => (
              <li class="list-disc">{item}</li>
            ))}
          </ul>
        </div>

        <div class="bg-bg-card border border-border rounded-xl p-6">
          <p class="text-accent text-sm font-mono uppercase tracking-wider mb-3">Why it mattered</p>
          <p class="text-text-secondary leading-relaxed">{study.whyItMattered}</p>
        </div>
      </section>

      <div class="mt-12 pt-8 border-t border-border flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4" data-animate data-delay="200">
        <p class="text-text-secondary text-sm max-w-xl">
          Want the fuller version or the role-specific resume? I can share that directly.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="/resume" class="inline-flex items-center gap-2 px-5 py-3 border border-border text-text-secondary rounded-lg hover:border-accent hover:text-accent transition-all text-sm" data-hover>
            Request resume
          </a>
          <a href="mailto:bibekgh@gmail.com?subject=Case%20study%20follow-up&body=Hi%20Bibek%2C%0A%0AI%E2%80%99d%20love%20to%20learn%20more%20about%20your%20work.%0A%0ACompany%3A%0ARole%3A%0AWhat%20would%20be%20most%20helpful%3A%0A" class="inline-flex items-center gap-2 px-5 py-3 bg-accent text-bg font-medium rounded-lg hover:bg-accent-hover transition-all text-sm" data-hover>
            Email Bibek
          </a>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
