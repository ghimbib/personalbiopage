---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { itemListSchema } from '../../utils/seo';

const title = 'Books | Bibek Ghimire';
const description = 'Children’s books and family stories by Bibek Ghimire.';
const canonicalPath = '/books/';
const books = [
  {
    title: 'Whirr, Wiggle, Outside!',
    href: '/books/whirr-wiggle-outside/',
    description: 'A tiny backyard rescue mission with Bruno, Riyan, Myra, Anvi, Captain Vacuum, and one very useful sock.',
    image: '/books/whirr-wiggle-outside/pages/front-cover.webp',
  },
];
const jsonLd = itemListSchema({
  name: 'Books by Bibek Ghimire',
  path: canonicalPath,
  items: books.map((book) => ({ name: book.title, url: book.href, description: book.description })),
});
---

<Layout title={title} description={description} canonicalPath={canonicalPath} jsonLd={jsonLd}>
  <Nav />
  <main id="main-content" class="min-h-screen px-6 pb-20 pt-32">
    <section class="mx-auto max-w-5xl space-y-10">
      <div class="space-y-4">
        <p class="font-mono text-sm uppercase tracking-[0.32em] text-accent">Books</p>
        <h1 class="text-4xl font-black text-text-primary md:text-6xl">Family stories</h1>
        <p class="max-w-2xl text-lg leading-relaxed text-text-secondary">Small books, made for actual bedtime readers.</p>
      </div>
      <div class="grid gap-6 md:grid-cols-2">
        {books.map((book) => (
          <a href={book.href} class="group overflow-hidden rounded-[2rem] border border-border bg-bg-card transition hover:-translate-y-1 hover:border-accent" data-hover>
            <img src={book.image} alt={`${book.title} cover`} class="aspect-square w-full object-cover" loading="lazy" />
            <div class="space-y-3 p-6">
              <h2 class="text-2xl font-black text-text-primary group-hover:text-accent">{book.title}</h2>
              <p class="text-text-secondary">{book.description}</p>
            </div>
          </a>
        ))}
      </div>
    </section>
  </main>
  <Footer />
</Layout>
